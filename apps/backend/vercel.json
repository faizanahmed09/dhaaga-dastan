{
  "outputDirectory": ".medusa/server/public",
  "rewrites": [
    {
      "source": "/app/assets/:path*",
      "destination": "/admin/assets/:path*"
    },
    {
      "source": "/app/:path*",
      "destination": "/admin/index.html"
    },
    {
      "source": "/admin/:path*",
      "destination": "/admin/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/",
      "destination": "/app",
      "permanent": true
    },
    {
      "source": "/admin",
      "destination": "/app",
      "permanent": true
    }
  ]
}
