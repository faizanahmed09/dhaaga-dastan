{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".medusa/server/**", ".next/**", "dist/**"],
      "env": [
        "NODE_ENV",
        "MEDUSA_BACKEND_URL",
        "NEXT_PUBLIC_MEDUSA_BACKEND_URL",
        "NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY",
        "NEXT_PUBLIC_BASE_URL",
        "NEXT_PUBLIC_DEFAULT_REGION",
        "DATABASE_URL",
        "STORE_CORS",
        "ADMIN_CORS",
        "AUTH_CORS",
        "JWT_SECRET",
        "COOKIE_SECRET",
        "S3_FILE_URL",
        "S3_ACCESS_KEY_ID",
        "S3_SECRET_ACCESS_KEY",
        "S3_REGION",
        "S3_BUCKET",
        "S3_ENDPOINT",
        "SUPABASE_PROJECT_ID",
        "SUPABASE_ACCESS_KEY",
        "SUPABASE_SECRET_KEY",
        "NEXT_PUBLIC_VERCEL_URL",
        "NEXT_PUBLIC_STRIPE_KEY",
        "NEXT_PUBLIC_MEDUSA_PAYMENTS_PUBLISHABLE_KEY",
        "NEXT_PUBLIC_MEDUSA_PAYMENTS_ACCOUNT_ID"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "dependsOn": ["^build"]
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "outputs": []
    },
    "seed": {
      "outputs": []
    }
  }
}
